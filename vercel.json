{
  "buildCommand": "vite build",
  "outputDirectory": "dist/client",
  "framework": null,
  "functions": {
    "api/[[...path]].js": {
      "runtime": "@vercel/node@5.0.0"
    }
  },
  "rewrites": [
    { "source": "/assets/:path*", "destination": "/assets/:path*" },
    { "source": "/(.*)", "destination": "/api/server" }
  ]
}
